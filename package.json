{
  "name": "eleventy-sample",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "kill": "pkill -f 'eleventy|tailwindcss|decap-server' || true",
    "css:build": "npx @tailwindcss/cli -i src/assets/styles/index.css -o _site/assets/styles/index.css --minify",
    "css:watch": "npx @tailwindcss/cli -i src/assets/styles/index.css -o _site/assets/styles/index.css --watch",
    "build": "npm run css:build && npx eleventy",
    "serve": "concurrently \"npm run css:watch\" \"npx eleventy --pathprefix=/site/ --serve\"",
    "build-ghpages": "npm run css:build && npx @11ty/eleventy --pathprefix=/site/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.2.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "cssnano": "^7.1.4",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2"
  },
  "type": "module"
}
