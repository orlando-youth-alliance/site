<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title + " | Orlando Youth Alliance" }}</title>

    <!-- additional styling for anything not covered by tailwindcss utility classes -->
    <link rel="stylesheet" href="/assets/styles/index.css">

    <!-- prevents flashing during dark/light mode switching, please do not remove -->
    <script src="/assets/js/theme.js"></script>

  </head>

  <body class="min-h-screen flex flex-col bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans">

    {% include "partials/header.njk" %}

    <main class="flex-1 max-w-4xl w-full mx-auto px-4 my-10 text-justify prose dark:prose-invert overflow-hidden">
      <h1 class="font-medium">{{ title | safe }}</h1>

      {% if donationLink %}
        {% include "partials/donateButton.njk" %}
      {% endif %}

{{ content | safe }}


    </main>

    {% include "partials/footer.njk" %}

  </body>
</html>
