<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title + " | Orlando Youth Alliance" }}</title>

    <!-- additional styling for anything not covered by tailwindcss utility classes -->
    <link rel="stylesheet" href="/assets/styles/index.css">

    <!-- prevents flashing during dark/light mode switching, please do not remove -->
    <script src="/assets/js/theme.js"></script>

  </head>

  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans">

    {% include "partials/header.njk" %}

    <main class="max-w-4xl mx-auto px-4 my-10 text-justify prose dark:prose-invert">
      <h1 class="font-medium">{{ title | safe }}</h1>

      {% for group in partners %}
      <div class="not-prose mt-8 mb-2">
        <h2 class="text-xl font-semibold text-gray-700 dark:text-gray-300">{{ group.tier }}</h2>
        <hr class="mt-2 border-gray-200 dark:border-gray-700">
      </div>
      <div class="not-prose grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-4 mb-6">
        {% for partner in group.items %}
        <div class="flex flex-col items-center justify-center p-4 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700">
          {% if partner.logo %}
          <a href="{{ partner.url }}" target="_blank" rel="noopener noreferrer">
            <img src="{{ partner.logo }}" class="max-h-20 max-w-full object-contain mb-2">
          </a>
          {% elif partner.url %}
          <a href="{{ partner.url }}" target="_blank" rel="noopener noreferrer"
            class="text-center text-sm font-medium text-blue-600 dark:text-blue-400 hover:underline">
            {{ partner.name }}
          </a>
          {% else %}
          <span class="text-center text-sm font-medium">{{ partner.name }}</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% endfor %}
    </main>

    {% include "partials/footer.njk" %}

  </body>
</html>
