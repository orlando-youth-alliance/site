<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title + " | Orlando Youth Alliance" }}</title>

    <!-- additional styling for anything not covered by tailwindcss utility classes -->
    <link rel="stylesheet" href="/assets/styles/index.css">

    <!-- prevents flashing during dark/light mode switching, please do not remove -->
    <script src="/assets/js/theme.js"></script>

  </head>

  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans">

    {% include "partials/header.njk" %}

    <main class="max-w-4xl mx-auto px-4 text-justify prose dark:prose-invert">
      <h1 class="font-medium">{{ title | safe }}</h1>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
        {% for partner in partners %}
        <div class="flex flex-col items-center justify-center p-4 rounded-lg shadow-sm border">
          {% if partner.logo %}
          <img src="{{partner.logo}}" class="max-h-20 max-w-full object-contain mb-2">
          {% endif %}
          <span class="text-center text-sm font-medium">
            {{ partner.name }}
          </span>
        </div>
        {% endfor %}
      </div>
    </main>

    {% include "partials/footer.njk" %}

  </body>
</html>
