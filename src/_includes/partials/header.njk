    <!-- Header -->
    <header class="fixed inset-x-0 top-0 z-50 flex items-center min-h-[88px] bg-white dark:bg-black shadow-md px-4 lg:px-8">
      <a href="/" class="shrink-0 mr-6">
        <!-- [OYA-HEADER] logo class sets max dimensions -->
        <img src="/assets/img/OYA-horizontal-white-dropshadow-text.png" alt="Orlando Youth Alliance" class="logo">
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex flex-1 items-center gap-6" aria-label="Main navigation">
        {% for item in nav %}
          <a href="{{ item.url }}" class="text-base hover:underline transition-colors">{{ item.label }}</a>
        {% endfor %}
      </nav>

      <div class="ml-auto flex items-center gap-3">
        <!-- Dark mode toggle: cycles system → dark → light → system -->
        <button id="dark-toggle" aria-label="Toggle color scheme" class="cursor-pointer p-2 rounded-lg transition-colors">
          <!-- system / auto: monitor with half-dark half-light screen -->
          <svg id="icon-system" class="hidden w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="15" rx="2"/>
            <path d="M12 17v2M9 19h6"/>
            <path d="M12 6a4 4 0 0 0 0 8z" fill="currentColor" stroke="none"/>
            <circle cx="12" cy="10" r="4"/>
          </svg>
          <!-- dark / moon -->
          <svg id="icon-dark" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
          </svg>
          <!-- light / sun -->
          <svg id="icon-light" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M3 12H1m22 0h-2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7z"/>
          </svg>
        </button>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" aria-label="Open navigation menu" aria-expanded="false" class="lg:hidden p-2 rounded-lg transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile nav drawer -->
    <nav id="mobile-nav" class="fixed inset-x-0 top-0 z-40 bg-white dark:bg-gray-950 shadow-lg pt-24 pb-6 px-6 hidden flex-col gap-4" aria-label="Mobile navigation">
      {% for item in nav %}
        <a href="{{ item.url }}" class="text-lg font-semibold hover:underline transition-colors">{{ item.label }}</a>
      {% endfor %}
    </nav>

    <!-- Spacer for fixed header -->
    <div class="min-h-[100px]"></div>
