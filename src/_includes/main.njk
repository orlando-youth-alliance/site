<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ siteConfig.site_title or "Orlando Youth Alliance" }}</title>
    <link rel="stylesheet" href="/assets/styles/index.css">
    <script>
      (function() {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (stored === null && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans">


    <!-- Header -->
    <header class="fixed inset-x-0 top-0 z-50 flex items-center min-h-[88px] bg-white dark:bg-black shadow-md px-4 lg:px-8">
      <a href="/" class="shrink-0 mr-6">
        <!-- [OYA-HEADER] logo class sets max dimensions -->
        <img src="/assets/img/OYA-horizontal-white-dropshadow-text.png" alt="Orlando Youth Alliance" class="logo">
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex flex-1 items-center gap-6" aria-label="Main navigation">
        {% for item in nav %}
          <a href="{{ item.url }}" class="text-base hover:underline transition-colors">{{ item.label }}</a>
        {% endfor %}
      </nav>

      <div class="ml-auto flex items-center gap-3">
        <!-- Dark mode toggle -->
        <button id="dark-toggle" aria-label="Toggle dark mode" class="p-2 rounded-lg transition-colors">
          <svg class="hidden dark:block w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M3 12H1m22 0h-2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42M12 7a5 5 0 1 0 0 10A5 5 0 0 0 12 7z"/>
          </svg>
          <svg class="block dark:hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"/>
          </svg>
        </button>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" aria-label="Open navigation menu" aria-expanded="false" class="lg:hidden p-2 rounded-lg transition-colors">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </header>

    <!-- Mobile nav drawer -->
    <nav id="mobile-nav" class="fixed inset-x-0 top-0 z-40 bg-white dark:bg-gray-950 shadow-lg pt-24 pb-6 px-6 hidden flex-col gap-4" aria-label="Mobile navigation">
      {% for item in nav %}
        <a href="{{ item.url }}" class="text-lg font-semibold hover:underline transition-colors">{{ item.label }}</a>
      {% endfor %}
    </nav>

    <!-- Spacer for fixed header -->
    <div class="min-h-[88px]"></div>

    <main>
      {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 dark:bg-gray-950 text-gray-300 py-10 px-6">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <p class="font-semibold text-white text-lg">Orlando Youth Alliance</p>
          <p class="text-sm mt-1">A 501(c)(3) nonprofit &mdash; A safe space for LGBT youth in Central Florida</p>
          <p class="text-sm mt-1 text-gray-500">&copy; {{ year }} Orlando Youth Alliance. All rights reserved.</p>
        </div>
        <nav class="flex flex-wrap justify-center gap-x-5 gap-y-2 text-sm" aria-label="Footer navigation">
          {% for item in nav %}
            <a href="{{ item.url }}" class="hover:text-white transition-colors">{{ item.label }}</a>
          {% endfor %}
        </nav>
      </div>
    </footer>

    <script src="/assets/js/theme.js"></script>

  </body>
</html>
